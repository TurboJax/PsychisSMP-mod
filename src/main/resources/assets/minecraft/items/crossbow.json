{
  "model": {
    "type": "minecraft:range_dispatch",
    "property": "minecraft:custom_model_data",
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:charge_type",
      "cases": [
        {"when": "arrow", "model": {"type": "minecraft:model", "model": "minecraft:item/crossbow_arrow"}},
        {"when": "rocket", "model": {"type": "minecraft:model", "model": "minecraft:item/crossbow_firework"}}
      ],
      "fallback": {
        "type": "minecraft:condition",
        "property": "minecraft:using_item",
        "on_false": {"type": "minecraft:model", "model": "minecraft:item/crossbow"},
        "on_true": {
          "type": "minecraft:range_dispatch",
          "property": "minecraft:crossbow/pull",
          "entries": [
            {"threshold": 0.58, "model": {"type": "minecraft:model", "model": "minecraft:item/crossbow_pulling_1"}},
            {"threshold": 1, "model": {"type": "minecraft:model", "model": "minecraft:item/crossbow_pulling_2"}}
          ],
          "fallback": {"type": "minecraft:model", "model": "minecraft:item/crossbow_pulling_0"}
        }
      }
    },
    "entries": [
      {
        "threshold": 1,
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:charge_type",
          "cases": [
            {"when": "arrow", "model": {"type": "minecraft:model", "model": "psychis-mod:item/charger_arrow"}},
            {"when": "rocket", "model": {"type": "minecraft:model", "model": "psychis-mod:item/charger_firework"}}
          ],
          "fallback": {
            "type": "minecraft:condition",
            "property": "minecraft:using_item",
            "on_false": {"type": "minecraft:model", "model": "psychis-mod:item/charger"},
            "on_true": {
              "type": "minecraft:range_dispatch",
              "property": "minecraft:crossbow/pull",
              "entries": [
                {"threshold": 0.58, "model": {"type": "minecraft:model", "model": "psychis-mod:item/charger_pulling_1"}},
                {"threshold": 1, "model": {"type": "minecraft:model", "model": "psychis-mod:item/charger_pulling_2"}}
              ],
              "fallback": {"type": "minecraft:model", "model": "psychis-mod:item/charger_pulling_0"}
            }
          }
        }
      }
    ]
  }
}